# OpenRouter — required for any model NOT prefixed with "nim:"
# Get a key at https://openrouter.ai/keys (free tier models available)
OPENROUTER_API_KEY=sk-or-v1-...

# NVIDIA NIM — required for any model prefixed with "nim:" (e.g., nim:qwen/qwen3-coder-480b-a35b-instruct)
# Get a key at https://build.nvidia.com (free credits on signup)
NVIDIA_API_KEY=nvapi-...
