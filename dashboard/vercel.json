{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "functions": {
    "app/api/playground/route.ts": {
      "maxDuration": 60
    },
    "app/api/leaderboard/route.ts": {
      "maxDuration": 5
    },
    "app/api/breakdown/route.ts": {
      "maxDuration": 5
    }
  }
}
